# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Database (defaults work with docker-compose; override for production)
# DB_USER=claudius
# DB_PASSWORD=claudius
# DB_NAME=claudius

# Garmin Connect
GARMIN_EMAIL=email@example.com
GARMIN_PASSWORD=password

# Strava OAuth2 — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/auth/strava/callback
# Dev only: copy "Your Access Token" and "Your Refresh Token" from strava.com/settings/api
# In production these are stored per-user in the database after OAuth
STRAVA_DEV_ACCESS_TOKEN=
STRAVA_DEV_REFRESH_TOKEN=

# TrainingPeaks — future/optional (API approval required)
# Training plans from your TP coach are already synced to Garmin calendar automatically.
# Use GET /api/sync/calendar to read them via Garmin instead.
# TRAININGPEAKS_CLIENT_ID=
# TRAININGPEAKS_CLIENT_SECRET=

# Telegram — @BotFather no Telegram -> /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=123456789

# URLs
BACKEND_URL=http://localhost:8000
